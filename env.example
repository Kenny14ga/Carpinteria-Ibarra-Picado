# Plantilla de Variables de Entorno - Pastelería Riquiquísimo

# URL de tu proyecto de Supabase (público)
NEXT_PUBLIC_SUPABASE_URL=https://tu-proyecto.supabase.co

# Llave anónima pública de tu proyecto de Supabase (público)
NEXT_PUBLIC_SUPABASE_ANON_KEY=tu-anon-key-aqui

# Llave de rol de servicio (SERVICE_ROLE_KEY) - ¡SENSITIVA, NUNCA EXPONER AL CLIENTE!
# Requerida en el servidor para crear y eliminar usuarios sin desloguear al administrador.
SUPABASE_SERVICE_ROLE_KEY=tu-service-role-key-aqui
